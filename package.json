{
  "name": "talentos",
  "version": "0.1.1",
  "private": true,
  "description": "TalentOS multi-tenant talent discovery, learning and recruitment platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:applicant": "npm run dev -w @talentos/applicant",
    "dev:admin": "npm run dev -w @talentos/admin",
    "dev:ops": "npm run dev -w @talentos/ops",
    "build": "npm run build -w @talentos/applicant && npm run build -w @talentos/admin",
    "lint": "npm run lint -w @talentos/applicant && npm run lint -w @talentos/admin",
    "typecheck": "tsc --noEmit && tsc --noEmit -p apps/applicant/tsconfig.json && tsc --noEmit -p apps/admin/tsconfig.json && tsc --noEmit -p apps/ops/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "regression:unit": "tsx scripts/regression/run.ts unit",
    "regression:auth": "tsx scripts/regression/run.ts auth",
    "regression:applicant": "tsx scripts/regression/run.ts applicant",
    "regression:admin": "tsx scripts/regression/run.ts admin",
    "regression:programs": "tsx scripts/regression/run.ts programs",
    "regression:missions": "tsx scripts/regression/run.ts missions",
    "regression:journal": "tsx scripts/regression/run.ts journal",
    "regression:tenant": "tsx scripts/regression/run.ts tenant",
    "regression:dashboard": "tsx scripts/regression/run.ts dashboard",
    "regression:storage": "tsx scripts/regression/run.ts storage",
    "regression:ops": "tsx scripts/regression/run.ts ops",
    "regression:all": "tsx scripts/regression/run.ts all",
    "ops:start": "npm run start -w @talentos/ops",
    "ops:cleanup-regression": "tsx scripts/cleanup-regression-data.ts",
    "local:bootstrap": "tsx scripts/local/bootstrap.ts",
    "local:doctor": "tsx scripts/local/doctor.ts",
    "local:smoke-login": "tsx scripts/local/smoke-login.ts",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "es-abstract": "^1.24.2",
    "prisma": "^6.10.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "lucide-react": "^1.23.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  }
}
