{
  "realm": "talentos",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "defaultRoles": ["APPLICANT"],
  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and notUsername(undefined) and passwordHistory(5)",
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyInitialCounter": 0,
  "otpPolicyLookAheadWindow": 1,
  "roles": {
    "realm": [
      { "name": "SUPER_ADMIN", "description": "Platform super admin: creates organizations and org admins" },
      { "name": "ORG_ADMIN", "description": "Organization admin: manages org users, roles, programs, settings" },
      { "name": "HR", "description": "Reviews applicants and hiring pipeline" },
      { "name": "TECH_LEAD", "description": "Evaluates applicant technical performance" },
      { "name": "APPLICANT", "description": "Applies, participates, submits work" }
    ]
  },
  "authenticationFlows": [
    {
      "id": "10000000-0000-4000-8000-000000000329",
      "alias": "talentos ops password browser",
      "description": "Browser login for the local Ops console without Keycloak TOTP.",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "autheticatorFlow": false,
          "userSetupAllowed": false
        }
      ]
    },
    {
      "id": "10000000-0000-4000-8000-000000000330",
      "alias": "talentos ops mfa browser",
      "description": "Browser login for the local Ops console with Keycloak TOTP required.",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "autheticatorFlow": false,
          "userSetupAllowed": false
        },
        {
          "authenticator": "auth-otp-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 20,
          "autheticatorFlow": false,
          "userSetupAllowed": false
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "talentos-ops",
      "name": "TalentOS Local Operations Console",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "talentos-ops-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://127.0.0.1:3300/auth/callback",
        "http://localhost:3300/auth/callback"
      ],
      "webOrigins": ["http://127.0.0.1:3300", "http://localhost:3300"],
      "attributes": {
        "post.logout.redirect.uris": "http://127.0.0.1:3300/*##http://localhost:3300/*"
      },
      "authenticationFlowBindingOverrides": {
        "browser": "10000000-0000-4000-8000-000000000329"
      },
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"]
    },
    {
      "clientId": "talentos-ops-mfa",
      "name": "TalentOS Local Operations Console MFA",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "talentos-ops-mfa-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://127.0.0.1:3300/auth/callback",
        "http://localhost:3300/auth/callback"
      ],
      "webOrigins": ["http://127.0.0.1:3300", "http://localhost:3300"],
      "attributes": {
        "post.logout.redirect.uris": "http://127.0.0.1:3300/*##http://localhost:3300/*"
      },
      "authenticationFlowBindingOverrides": {
        "browser": "10000000-0000-4000-8000-000000000330"
      },
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"]
    },
    {
      "clientId": "talentos-applicant",
      "name": "TalentOS Applicant Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "talentos-applicant-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3100/api/auth/callback/keycloak",
        "http://localhost:3100/*",
        "http://lvh.me:3100/api/auth/callback/keycloak",
        "http://lvh.me:3100/*",
        "http://*.lvh.me:3100/*"
      ],
      "webOrigins": ["http://localhost:3100", "http://lvh.me:3100", "http://*.lvh.me:3100"],
      "attributes": { "post.logout.redirect.uris": "http://localhost:3100/*##http://lvh.me:3100/*##http://*.lvh.me:3100/*" },
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"]
    },
    {
      "clientId": "talentos-admin",
      "name": "TalentOS Admin Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "talentos-admin-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3200/api/auth/callback/keycloak",
        "http://localhost:3200/*",
        "http://lvh.me:3200/api/auth/callback/keycloak",
        "http://lvh.me:3200/*",
        "http://*.lvh.me:3200/*"
      ],
      "webOrigins": ["http://localhost:3200", "http://lvh.me:3200", "http://*.lvh.me:3200"],
      "attributes": { "post.logout.redirect.uris": "http://localhost:3200/*##http://lvh.me:3200/*##http://*.lvh.me:3200/*" },
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"]
    },
    {
      "clientId": "talentos-provisioner",
      "name": "TalentOS Admin Provisioner (service account)",
      "description": "Confidential service-account client used by the admin app to create org-admin users and grant realm roles via the Keycloak Admin REST API.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "talentos-provisioner-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": ["roles"]
    }
  ],
