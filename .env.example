# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=TalentOS
APP_BASE_DOMAIN=localhost
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Web containers (isolated applicant and admin modules)
APPLICANT_PORT=3100
ADMIN_PORT=3200
NEXTAUTH_URL=http://localhost:3100
ADMIN_NEXTAUTH_URL=http://localhost:3200
# Admin links back to the applicant portal; the applicant portal exposes no admin navigation.
NEXT_PUBLIC_APPLICANT_URL=http://localhost:3100

# Keycloak IAM (v0.3.0) — authentication and RBAC
KEYCLOAK_PORT=8080
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
KC_DB_USER=keycloak
KC_DB_PASSWORD=keycloak_dev_password
KC_DB_NAME=keycloak
# Same issuer URL for browser (Docker Desktop maps host.docker.internal) and app containers.
KC_HOSTNAME=http://host.docker.internal:8080
KEYCLOAK_ISSUER=http://host.docker.internal:8080/realms/talentos
KEYCLOAK_APPLICANT_CLIENT_ID=talentos-applicant
KEYCLOAK_APPLICANT_CLIENT_SECRET=talentos-applicant-secret
KEYCLOAK_ADMIN_CLIENT_ID=talentos-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=talentos-admin-secret

# Database
POSTGRES_USER=talentos
POSTGRES_PASSWORD=talentos_dev_password
POSTGRES_DB=talentos
POSTGRES_PORT=5432
DATABASE_URL=postgresql://talentos:talentos_dev_password@localhost:5432/talentos?schema=public

# Optional local tenant simulation
DEFAULT_TENANT_SLUG=demo
