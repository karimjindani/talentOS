# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=TalentOS
# Base domain for subdomain-per-tenant addressing (v0.12.1, D-060). lvh.me and *.lvh.me resolve to
# 127.0.0.1 with no host-file setup, so a tenant is reachable at e.g. sbp.lvh.me:3200. The auth
# session cookie is scoped to this domain (`.lvh.me`) so a login on the canonical host below is valid
# on every tenant subdomain. In production set this to your real base domain (e.g. talentos.io).
APP_BASE_DOMAIN=lvh.me
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Web containers (isolated applicant and admin modules)
APPLICANT_PORT=3100
ADMIN_PORT=3200
# Canonical login host per app (must NOT be a tenant subdomain — the apex resolves to the default
# tenant). Login always runs through this host so next-auth can mint a stable OIDC redirect_uri;
# users are redirected back to their own tenant subdomain afterward (v0.12.1, D-060).
NEXTAUTH_URL=http://lvh.me:3100
ADMIN_NEXTAUTH_URL=http://lvh.me:3200
# Admin links back to the applicant portal; the applicant portal exposes no admin navigation.
NEXT_PUBLIC_APPLICANT_URL=http://lvh.me:3100

# Keycloak IAM (v0.3.0) — authentication and RBAC
KEYCLOAK_PORT=8080
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
KC_DB_USER=keycloak
KC_DB_PASSWORD=keycloak_dev_password
KC_DB_NAME=keycloak
# Same issuer URL for browser (Docker Desktop maps host.docker.internal) and app containers.
KC_HOSTNAME=http://host.docker.internal:8080
KEYCLOAK_ISSUER=http://host.docker.internal:8080/realms/talentos
KEYCLOAK_APPLICANT_CLIENT_ID=talentos-applicant
KEYCLOAK_APPLICANT_CLIENT_SECRET=talentos-applicant-secret
KEYCLOAK_ADMIN_CLIENT_ID=talentos-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=talentos-admin-secret
# Admin REST provisioning (v0.11.0) — service account used to auto-provision org admins.
KEYCLOAK_SERVER_URL=http://host.docker.internal:8080
KEYCLOAK_REALM=talentos
KEYCLOAK_PROVISIONER_CLIENT_ID=talentos-provisioner
KEYCLOAK_PROVISIONER_CLIENT_SECRET=talentos-provisioner-secret
OPS_KEYCLOAK_CLIENT_ID=talentos-ops
OPS_KEYCLOAK_CLIENT_SECRET=talentos-ops-secret
OPS_KEYCLOAK_MFA_CLIENT_ID=talentos-ops-mfa
OPS_KEYCLOAK_MFA_CLIENT_SECRET=talentos-ops-mfa-secret

# Database
POSTGRES_USER=talentos
POSTGRES_PASSWORD=talentos_dev_password
POSTGRES_DB=talentos
POSTGRES_PORT=5432
DATABASE_URL=postgresql://talentos:talentos_dev_password@localhost:5432/talentos?schema=public

# Object storage (MinIO, S3-compatible) — v0.7.0
# Same endpoint for browser (presigned URLs) and containers via host.docker.internal.
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_ENDPOINT=http://host.docker.internal:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=talentos
S3_SECRET_ACCESS_KEY=talentos_dev_password
S3_BUCKET=talentos
S3_FORCE_PATH_STYLE=true

# Optional local tenant simulation
DEFAULT_TENANT_SLUG=demo

# Local out-of-band Operations console (host-only, not committed in .env)
OPS_HOST=127.0.0.1
OPS_PORT=3300
OPS_BASE_URL=http://127.0.0.1:3300
OPS_ALLOWED_ROLES=SUPER_ADMIN,ORG_ADMIN
OPS_SESSION_SECRET=replace-with-a-long-random-ops-secret
