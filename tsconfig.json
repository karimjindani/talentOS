{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@talentos/auth": ["packages/auth/src"],
      "@talentos/auth/*": ["packages/auth/src/*"],
      "@talentos/db": ["packages/db/src"],
      "@talentos/storage": ["packages/storage/src"],
      "@talentos/storage/*": ["packages/storage/src/*"],
      "@talentos/ui": ["packages/ui/src"],
      "@talentos/ui/*": ["packages/ui/*"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}
