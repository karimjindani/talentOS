generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum TenantRole {
  OWNER
  ADMIN
  APPLICANT
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WAITLISTED
}

enum MissionDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  NEEDS_REVISION
  ACCEPTED
}

model Tenant {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  logoUrl         String?
  primaryColor    String            @default("#2563eb")
  secondaryColor  String            @default("#0f172a")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  memberships     TenantMembership[]
  programs        Program[]
  applications    Application[]
  auditLogs       AuditLog[]
  missions        Mission[]
  portfolioItems  PortfolioArtifact[]
  certificates    Certificate[]
  knowledgeDocs   KnowledgeBaseDocument[]
  aiInteractions  AIInteraction[]

  @@map("tenants")
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  name                  String?
  passwordHash          String
  status                UserStatus         @default(ACTIVE)
  totpSecretEncrypted   String?
  totpEnabledAt         DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  memberships           TenantMembership[]
  applications          Application[]      @relation("ApplicantApplications")
  auditLogs             AuditLog[]
  submissions           Submission[]
  aiInteractions        AIInteraction[]

  @@map("users")
}

model TenantMembership {
  id          String      @id @default(cuid())
  tenantId    String
  userId      String
  role        TenantRole
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, role])
  @@index([tenantId, role])
  @@index([userId])
  @@map("tenant_memberships")
}

model Program {
  id            String         @id @default(cuid())
  tenantId      String
  name          String
  slug          String
  description   String
  status        ProgramStatus  @default(DRAFT)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications  Application[]
  missions      Mission[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("programs")
}

model Application {
  id            String              @id @default(cuid())
  tenantId      String
  programId     String
  applicantId   String
  status        ApplicationStatus   @default(DRAFT)
  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewerNotes String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program       Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  applicant     User                @relation("ApplicantApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  answers       ApplicationAnswer[]

  @@index([tenantId, status])
  @@index([programId, status])
  @@index([applicantId])
  @@map("applications")
}

model ApplicationAnswer {
  id             String       @id @default(cuid())
  applicationId  String
  questionKey    String
  questionLabel  String
  answer         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionKey])
  @@map("application_answers")
}

model AuditLog {
  id          String    @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor       User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model Mission {
  id          String             @id @default(cuid())
  tenantId    String
  programId   String
  title       String
  difficulty  MissionDifficulty
  brief       String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([tenantId, programId])
  @@map("missions")
}

model Submission {
  id             String            @id @default(cuid())
  missionId       String
  applicantId     String
  status          SubmissionStatus @default(DRAFT)
  repositoryUrl   String?
  deploymentUrl   String?
  loomUrl         String?
  journalMarkdown String?
  submittedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  mission         Mission           @relation(fields: [missionId], references: [id], onDelete: Cascade)
  applicant       User              @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([missionId, status])
  @@index([applicantId])
  @@map("submissions")
}

model PortfolioArtifact {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  url         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("portfolio_artifacts")
}

model Certificate {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  issuedTo    String
  issuedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("certificates")
}

model KnowledgeBaseDocument {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("knowledge_base_documents")
}

model AIInteraction {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  purpose     String
  promptHash  String?
  responseRef String?
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@map("ai_interactions")
}
