generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum TenantRole {
  ORG_ADMIN
  HR
  TECH_LEAD
  APPLICANT
}

enum PlatformRole {
  SUPER_ADMIN
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WAITLISTED
}

enum MissionDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  NEEDS_REVISION
  ACCEPTED
}

enum FileStatus {
  PENDING
  READY
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  TASK_DUE
}

model Tenant {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  logoUrl         String?
  primaryColor    String            @default("#2563eb")
  secondaryColor  String            @default("#0f172a")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  logoFileId      String?            @unique
  logoFile        StoredFile?        @relation("TenantLogo", fields: [logoFileId], references: [id], onDelete: SetNull)

  memberships     TenantMembership[]
  programs        Program[]
  applications    Application[]
  auditLogs       AuditLog[]
  missions        Mission[]
  portfolioItems  PortfolioArtifact[]
  certificates    Certificate[]
  knowledgeDocs   KnowledgeBaseDocument[]
  aiInteractions  AIInteraction[]
  storedFiles     StoredFile[]
  programTasks    ProgramTask[]
  videoResources  VideoResource[]
  notifications   Notification[]
  calendarEvents  CalendarEvent[]

  @@map("tenants")
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  name                  String?
  // Optional since Keycloak owns credentials as of v0.3.0; local password is legacy.
  passwordHash          String?
  keycloakSubjectId     String?            @unique
  emailVerified         DateTime?
  platformRole          PlatformRole?
  status                UserStatus         @default(ACTIVE)
  totpSecretEncrypted   String?
  totpEnabledAt         DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  memberships           TenantMembership[]
  applications          Application[]      @relation("ApplicantApplications")
  auditLogs             AuditLog[]
  submissions           Submission[]
  aiInteractions        AIInteraction[]
  storedFiles           StoredFile[]
  notifications         Notification[]
  taskCompletions       UserTaskCompletion[]

  @@map("users")
}

model TenantMembership {
  id          String      @id @default(cuid())
  tenantId    String
  userId      String
  role        TenantRole
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, role])
  @@index([tenantId, role])
  @@index([userId])
  @@map("tenant_memberships")
}

model Program {
  id            String         @id @default(cuid())
  tenantId      String
  name          String
  slug          String
  description   String
  status        ProgramStatus  @default(DRAFT)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications  Application[]
  missions      Mission[]
  tasks         ProgramTask[]
  videoResources VideoResource[]
  calendarEvents CalendarEvent[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("programs")
}

model Application {
  id            String              @id @default(cuid())
  tenantId      String
  programId     String
  applicantId   String
  status        ApplicationStatus   @default(DRAFT)
  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewerNotes String?
  githubUrl     String?
  linkedinUrl   String?
  cvFileId      String?             @unique
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program       Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  applicant     User                @relation("ApplicantApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  cvFile        StoredFile?         @relation("ApplicationCv", fields: [cvFileId], references: [id], onDelete: SetNull)
  answers       ApplicationAnswer[]

  @@index([tenantId, status])
  @@index([programId, status])
  @@index([applicantId])
  @@map("applications")
}

model ApplicationAnswer {
  id             String       @id @default(cuid())
  applicationId  String
  questionKey    String
  questionLabel  String
  answer         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionKey])
  @@map("application_answers")
}

model AuditLog {
  id          String    @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor       User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model Mission {
  id          String             @id @default(cuid())
  tenantId    String
  programId   String
  title       String
  difficulty  MissionDifficulty
  brief       String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([tenantId, programId])
  @@map("missions")
}

model Submission {
  id             String            @id @default(cuid())
  missionId       String
  applicantId     String
  status          SubmissionStatus @default(DRAFT)
  repositoryUrl   String?
  deploymentUrl   String?
  loomUrl         String?
  journalMarkdown String?
  submittedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  mission         Mission           @relation(fields: [missionId], references: [id], onDelete: Cascade)
  applicant       User              @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([missionId, status])
  @@index([applicantId])
  @@map("submissions")
}

model PortfolioArtifact {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  url         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("portfolio_artifacts")
}

model Certificate {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  issuedTo    String
  issuedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("certificates")
}

model KnowledgeBaseDocument {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("knowledge_base_documents")
}

model AIInteraction {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  purpose     String
  promptHash  String?
  responseRef String?
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@map("ai_interactions")
}

model StoredFile {
  id           String     @id @default(cuid())
  tenantId     String
  ownerUserId  String?
  bucket       String
  storageKey   String     @unique
  originalName String
  contentType  String
  size         Int
  category     String
  status       FileStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner        User?        @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  cvForApplication Application? @relation("ApplicationCv")
  logoForTenant    Tenant?      @relation("TenantLogo")

  @@index([tenantId, category])
  @@index([ownerUserId])
  @@map("stored_files")
}

model RegressionDataMarker {
  id          String   @id @default(cuid())
  runId       String
  entityType  String
  entityId    String
  createdAt   DateTime @default(now())

  @@unique([entityType, entityId])
  @@index([runId])
  @@index([entityType, entityId])
  @@map("regression_data_markers")
}

/// A task/assignment scoped to a program and a specific week (1-4).
model ProgramTask {
  id          String   @id @default(cuid())
  tenantId    String
  programId   String
  weekNumber  Int
  title       String
  description String?
  dueAt       DateTime?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  completions UserTaskCompletion[]

  @@index([tenantId, programId, weekNumber])
  @@map("program_tasks")
}

/// A video resource (external URL — YouTube/Loom) scoped to a program and optionally a week.
model VideoResource {
  id          String   @id @default(cuid())
  tenantId    String
  programId   String
  weekNumber  Int?
  title       String
  url         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([tenantId, programId, weekNumber])
  @@map("video_resources")
}

/// An in-app notification for a specific user.
model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType @default(INFO)
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

/// A scheduled calendar event for a program.
model CalendarEvent {
  id          String   @id @default(cuid())
  tenantId    String
  programId   String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([tenantId, programId, startsAt])
  @@map("calendar_events")
}

/// Join table tracking which applicant has completed a ProgramTask.
model UserTaskCompletion {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  completedAt DateTime @default(now())

  task      ProgramTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("user_task_completions")
}
