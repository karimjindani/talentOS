generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum TenantRole {
  ORG_ADMIN
  HR
  TECH_LEAD
  APPLICANT
}

enum PlatformRole {
  SUPER_ADMIN
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WAITLISTED
}

enum MissionDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum MissionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  NEEDS_REVISION
  ACCEPTED
  REPEAT
}

enum MissionAssignmentStatus {
  ACTIVE
  SUBMITTED
  PASSED
  REPEAT
}

enum FileStatus {
  PENDING
  READY
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  TASK_DUE
}

enum LearningResourceType {
  MARKDOWN
  YOUTUBE
}

model Tenant {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  primaryColor   String   @default("#2563eb")
  secondaryColor String   @default("#0f172a")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  logoFileId String?     @unique
  logoFile   StoredFile? @relation("TenantLogo", fields: [logoFileId], references: [id], onDelete: SetNull)

  memberships        TenantMembership[]
  programs           Program[]
  applications       Application[]
  auditLogs          AuditLog[]
  missions           Mission[]
  portfolioItems     PortfolioArtifact[]
  certificates       Certificate[]
  knowledgeDocs      KnowledgeBaseDocument[]
  aiInteractions     AIInteraction[]
  storedFiles        StoredFile[]
  programTasks       ProgramTask[]
  videoResources     VideoResource[]
  taskCompletions    UserTaskCompletion[]
  notifications      Notification[]
  calendarEvents     CalendarEvent[]
  submissions        Submission[]
  journalEntries     EngineeringJournalEntry[]
  missionAssignments MissionAssignment[]

  @@map("tenants")
}

model User {
  id                       String        @id @default(cuid())
  email                    String        @unique
  name                     String?
  // Optional since Keycloak owns credentials as of v0.3.0; local password is legacy.
  passwordHash             String?
  keycloakSubjectId        String?       @unique
  emailVerified            DateTime?
  platformRole             PlatformRole?
  status                   UserStatus    @default(ACTIVE)
  totpSecretEncrypted      String?
  totpEnabledAt            DateTime?
  lastLoginAt              DateTime?
  preferredJournalLanguage String        @default("English")
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  memberships         TenantMembership[]
  applications        Application[]             @relation("ApplicantApplications")
  auditLogs           AuditLog[]
  submissions         Submission[]              @relation("SubmissionApplicant")
  reviewedSubmissions Submission[]              @relation("SubmissionReviewer")
  journalEntries      EngineeringJournalEntry[] @relation("JournalEntryApplicant")
  missionAssignments  MissionAssignment[]       @relation("MissionAssignmentApplicant")
  aiInteractions      AIInteraction[]
  storedFiles         StoredFile[]
  notifications       Notification[]
  taskCompletions     UserTaskCompletion[]

  @@map("users")
}

model TenantMembership {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, role])
  @@index([tenantId, role])
  @@index([userId])
  @@map("tenant_memberships")
}

model Program {
  id          String        @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String
  status      ProgramStatus @default(DRAFT)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant             Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications       Application[]
  missions           Mission[]
  tasks              ProgramTask[]
  videoResources     VideoResource[]
  calendarEvents     CalendarEvent[]
  journalEntries     EngineeringJournalEntry[]
  missionAssignments MissionAssignment[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("programs")
}

model Application {
  id            String            @id @default(cuid())
  tenantId      String
  programId     String
  applicantId   String
  status        ApplicationStatus @default(DRAFT)
  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewerNotes String?
  githubUrl     String?
  linkedinUrl   String?
  cvFileId      String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program   Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  applicant User                @relation("ApplicantApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  cvFile    StoredFile?         @relation("ApplicationCv", fields: [cvFileId], references: [id], onDelete: SetNull)
  answers   ApplicationAnswer[]

  @@index([tenantId, status])
  @@index([programId, status])
  @@index([applicantId])
  @@map("applications")
}

model ApplicationAnswer {
  id            String   @id @default(cuid())
  applicationId String
  questionKey   String
  questionLabel String
  answer        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionKey])
  @@map("application_answers")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor  User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model Mission {
  id                 String            @id @default(cuid())
  tenantId           String
  programId          String
  title              String
  difficulty         MissionDifficulty
  status             MissionStatus     @default(DRAFT)
  weekNumber         Int               @default(1)
  order              Int               @default(0)
  brief              String
  objective          String            @default("")
  acceptanceCriteria String            @default("")
  deliverables       String            @default("")
  evaluationCriteria String            @default("")
  competencyTags     String[]          @default([])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program        Program                   @relation(fields: [programId], references: [id], onDelete: Cascade)
  submissions    Submission[]
  journalEntries EngineeringJournalEntry[]
  assignments    MissionAssignment[]

  @@index([tenantId, programId, status])
  @@index([tenantId, status])
  @@map("missions")
}

model MissionAssignment {
  id            String                  @id @default(cuid())
  tenantId      String
  programId     String
  applicantId   String
  missionId     String
  weekNumber    Int
  attemptNumber Int                     @default(1)
  status        MissionAssignmentStatus @default(ACTIVE)
  assignedAt    DateTime                @default(now())
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program        Program                   @relation(fields: [programId], references: [id], onDelete: Cascade)
  applicant      User                      @relation("MissionAssignmentApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  mission        Mission                   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  submissions    Submission[]
  journalEntries EngineeringJournalEntry[]

  @@unique([tenantId, programId, applicantId, weekNumber, attemptNumber], map: "mission_assignment_attempt_key")
  @@index([tenantId, programId, weekNumber])
  @@index([applicantId])
  @@index([missionId])
  @@map("mission_assignments")
}

model Submission {
  id                  String           @id @default(cuid())
  // Direct tenant scoping (v0.15.0, D-067), consistent with every other tenant-owned table.
  tenantId            String
  missionId           String
  applicantId         String
  missionAssignmentId String?          @unique(map: "submission_assignment_key")
  status              SubmissionStatus @default(DRAFT)
  repositoryUrl       String?
  deploymentUrl       String?
  loomUrl             String?
  journalMarkdown     String?
  submittedAt         DateTime?
  reviewerFeedback    String?
  reviewedAt          DateTime?
  reviewerUserId      String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mission           Mission            @relation(fields: [missionId], references: [id], onDelete: Cascade)
  applicant         User               @relation("SubmissionApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  reviewer          User?              @relation("SubmissionReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  missionAssignment MissionAssignment? @relation(fields: [missionAssignmentId], references: [id], onDelete: SetNull)

  // One submission row per assignment attempt; the SEM revision loop reuses that attempt's row.
  @@index([missionId, status])
  @@index([applicantId])
  @@index([tenantId, status])
  @@map("submissions")
}

model EngineeringJournalEntry {
  id                        String    @id @default(cuid())
  tenantId                  String
  applicantId               String
  programId                 String
  missionId                 String
  missionAssignmentId       String?
  weekNumber                Int
  entryDate                 DateTime
  language                  String
  workedOn                  String
  challenge                 String
  solution                  String
  learned                   String
  aiUsage                   String
  confidenceRating          Int
  timeSpentHours            Float
  evidenceLinks             String[]  @default([])
  reflectionDepthScore      Int?
  problemSolvingScore       Int?
  learningQualityScore      Int?
  communicationClarityScore Int?
  consistencyScore          Int?
  totalScore                Int?
  aiReviewFeedback          String?
  aiReviewedAt              DateTime?
  aiReviewMetadata          Json?
  lockedAt                  DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applicant         User               @relation("JournalEntryApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  program           Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  mission           Mission            @relation(fields: [missionId], references: [id], onDelete: Cascade)
  missionAssignment MissionAssignment? @relation(fields: [missionAssignmentId], references: [id], onDelete: SetNull)

  @@unique([tenantId, applicantId, entryDate])
  @@index([tenantId, programId, weekNumber])
  @@index([missionId])
  @@index([missionAssignmentId, entryDate])
  @@map("engineering_journal_entries")
}

model PortfolioArtifact {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  url         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("portfolio_artifacts")
}

model Certificate {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  issuedTo  String
  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("certificates")
}

model KnowledgeBaseDocument {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("knowledge_base_documents")
}

model AIInteraction {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  purpose     String
  promptHash  String?
  responseRef String?
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@map("ai_interactions")
}

model StoredFile {
  id           String     @id @default(cuid())
  tenantId     String
  ownerUserId  String?
  bucket       String
  storageKey   String     @unique
  originalName String
  contentType  String
  size         Int
  category     String
  status       FileStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner            User?        @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  cvForApplication Application? @relation("ApplicationCv")
  logoForTenant    Tenant?      @relation("TenantLogo")

  @@index([tenantId, category])
  @@index([ownerUserId])
  @@map("stored_files")
}

model RegressionDataMarker {
  id         String   @id @default(cuid())
  runId      String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  @@unique([entityType, entityId])
  @@index([runId])
  @@index([entityType, entityId])
  @@map("regression_data_markers")
}

/// A learning task scoped to a tenant-owned program week, independent of mission attempts.
model ProgramTask {
  id          String    @id @default(cuid())
  tenantId    String
  programId   String
  weekNumber  Int
  title       String
  description String?
  dueAt       DateTime?
  order       Int       @default(0)
  required    Boolean   @default(true)
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  completions UserTaskCompletion[]
  resources   VideoResource[]

  @@index([tenantId, programId, weekNumber, published, order])
  @@map("program_tasks")
}

/// A Markdown or YouTube learning resource; legacy model/table name retained for compatibility.
model VideoResource {
  id              String               @id @default(cuid())
  tenantId        String
  programId       String
  taskId          String?
  weekNumber      Int?
  type            LearningResourceType @default(YOUTUBE)
  title           String
  url             String?
  markdownContent String?
  description     String?
  order           Int                  @default(0)
  durationSeconds Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  task    ProgramTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([tenantId, programId, weekNumber])
  @@index([tenantId, taskId, order])
  @@map("video_resources")
}

/// An in-app notification for a specific user.
model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType @default(INFO)
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

/// A scheduled calendar event for a program.
model CalendarEvent {
  id          String    @id @default(cuid())
  tenantId    String
  programId   String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([tenantId, programId, startsAt])
  @@map("calendar_events")
}

/// Join table tracking which applicant has completed a ProgramTask.
model UserTaskCompletion {
  id          String   @id @default(cuid())
  tenantId    String
  taskId      String
  userId      String
  completedAt DateTime @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  task ProgramTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, taskId])
  @@index([tenantId, userId])
  @@index([tenantId, taskId])
  @@map("user_task_completions")
}
