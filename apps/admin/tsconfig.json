{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@talentos/auth": [
        "../../packages/auth/src"
      ],
      "@talentos/auth/*": [
        "../../packages/auth/src/*"
      ],
      "@talentos/auth-web": [
        "../../packages/auth-web/src"
      ],
      "@talentos/auth-web/*": [
        "../../packages/auth-web/src/*"
      ],
      "@talentos/db": [
        "../../packages/db/src"
      ],
      "@talentos/storage": [
        "../../packages/storage/src"
      ],
      "@talentos/ui": [
        "../../packages/ui/src"
      ],
      "@talentos/ui/*": [
        "../../packages/ui/*"
      ]
    },
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
